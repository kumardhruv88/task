# ─── App ───────────────────────────────────────────────────────────────────────
# Database — NEVER commit this
DATABASE_URL="postgresql://user:password@host:5432/affiliate_payout?schema=public&sslmode=require"

# ─── Auth.js (NextAuth v5) ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Public ────────────────────────────────────────────────────────────────────
# Exposed to the browser — never put secrets here
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Affiliate Payout System"

# ─── Optional: Neon DB (recommended for Vercel deployments) ────────────────────
# Neon provides connection pooling — use pooled URL for serverless functions
# DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech:5432/affiliate_payout?sslmode=require"
